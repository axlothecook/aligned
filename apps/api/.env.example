# Copy to .env (gitignored) and fill in. Local dev defaults match docker-compose.yml.

# Postgres connection (host 5433 → the docker container's 5432)
DATABASE_URL=postgresql://aligned:aligned_dev_pw@localhost:5433/aligned

# API server port
PORT=4000

# Where the web app runs (for CORS + email verification links)
WEB_BASE_URL=http://localhost:3000

# Secrets — use long random strings. (Dev values are fine locally; rotate for prod.)
SESSION_SECRET=dev_session_secret_change_me
JWT_SECRET=dev_jwt_secret_change_me

# Email (Brevo). Leave UNSET in dev → emails are logged to the console instead of
# sent. Set both at deploy to actually send.
# BREVO_API_KEY=
# EMAIL_FROM=no-reply@yourdomain.com
